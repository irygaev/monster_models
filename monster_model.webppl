var prod_data_no_training = json.read('prod_data_no_training.json')
var prod_data_no_training_first = json.read('prod_data_no_training_first.json')
var prod_data_no_training_rest = json.read('prod_data_no_training_rest.json')
var prod_data_training = json.read('prod_data_training.json')
var prod_data_training_familiar = json.read('prod_data_training_familiar.json')
var prod_data_training_surprising = json.read('prod_data_training_surprising.json')
var prod_data_training_postsurprising = json.read('prod_data_training_postsurprising.json')

var perc_data_clean = json.read('perc_data_clean.json')
var perc_data_clean_heard = json.read('perc_data_clean_heard.json')
var perc_data_high_noise = json.read('perc_data_high_noise.json')
var perc_data_high_noise_heard = json.read('perc_data_high_noise_heard.json')
var perc_data_low_noise = json.read('perc_data_low_noise.json')
var perc_data_low_noise_heard = json.read('perc_data_low_noise_heard.json')
var perc_data_noise = json.read('perc_data_noise.json')
var perc_data_noise_heard = json.read('perc_data_noise_heard.json')

var action_priors = {
  jump_over: 0.4391667,
  wave: 0.6422917,
  attack: 0.6800000,
  throw_rock: 0.9372917,
  overall: 0.67585
}

////////////
// RSA MODEL
////////////

// set of states
var states = ["agent_falls", "patient_falls"]

// set of utterances
var utterances = ["the_agent", "the_patient", "it", "zero"]

var confusionProb = function(i_utt, p_utt, params)
{
    var certain_zero = params.certain_zero
    var certain_it = params.certain_it

    if (i_utt == 'it')
    {
        if (p_utt == 'it')
            return certain_it
        else if (p_utt == 'zero')
            return 1 - certain_it
        else
            return 0
    }
    else if (i_utt == 'zero')
    {
        if (p_utt == 'zero')
            return certain_zero
        else if (p_utt == 'it')
            return 1 - certain_zero
        else
            return 0
    }
    else if (i_utt == p_utt)
        return 1
    else
        return 0
}

// function for utterance costs
var cost = function(utterance, params) {
  return (utterance === "the_agent" || utterance === "the_patient") ? params.np_cost : ((utterance == "it") ? params.pro_cost : 0)
}

var utterancePriors = function(state, params)
{
  var utt_probs = map(function(utterance) {return Math.exp(-params.alpha * cost(utterance, params))}, utterances)
  
  var subj_bias = map2(function(x, y) {return x * y}, [1 - params.subject_bias, 1 - params.subject_bias, params.subject_bias, params.subject_bias], utt_probs)
  var obj_bias = map2(function(x, y) {return x * y}, [params.subject_bias, params.subject_bias, 1 - params.subject_bias, 1 - params.subject_bias], utt_probs)

  return state == "agent_falls" ? (subj_bias) :
         state == "patient_falls" ? (obj_bias) : 
        [0.25, 0.25, 0.25, 0.25]
}

var utterancePrior = function(utterance, state, params)
{
  return utterancePriors(state, params)[utterances.indexOf(utterance)]
}

var utteranceByPrior = function(state, params)
{
    var utt_priors = utterancePriors(state, params)
    return categorical(utt_priors, utterances)
}

var perceivedUtteranceSample = function(i_utt, params)
{
  var probs = map(function(p_utt) { return confusionProb(i_utt, p_utt, params) }, utterances)
  return categorical(probs, utterances)
}

var reverseConfusionProbs = function(p_utt, state, params)
{
  var utt_weights = map(function(utterance) { return utterancePrior(utterance, state, params) * confusionProb(utterance, p_utt, params)}, utterances)
  var utt_probs = map(function(x) { return x / sum(utt_weights)}, utt_weights)

  return utt_probs
}

var reverseConfusionProb = function(p_utt, i_utt, state, params)
{
  var utt_probs = reverseConfusionProbs(p_utt, state, params)
  return utt_probs[utterances.indexOf(i_utt)]
}

var intendedUtterancePosterior = function(p_utt, state, params)
{
  var utt_priors = reverseConfusionProbs(p_utt, state, params)
  return Categorical({ps: utt_priors, vs: utterances})
}

var intendedUtterancePosteriorSlow = function(p_utt, state, params)
{
  Infer({method: 'enumerate', model: function() {
    var i_utt = utteranceByPrior(state, params)
    condition(p_utt === perceivedUtteranceSample(i_utt, params))
    return i_utt
  }})
}

var doubleConfusionProbs = function(speaker_i_utt, state, params)
{
  var utt_weights = map(function(i_utt)
    {
      return sum(map(function(p_utt)
        {
          return confusionProb(speaker_i_utt, p_utt, params) * reverseConfusionProb(p_utt, i_utt, state, params)
        },
        utterances
      ))
    },
    utterances
  )

  var utt_probs = map(function(x) { return x / sum(utt_weights)}, utt_weights)

  return utt_probs
}

var doubleConfusionProb = function(speaker_i_utt, listener_i_utt, state, params)
{
  var utt_probs = doubleConfusionProbs(speaker_i_utt, state, params)
  return utt_probs[utterances.indexOf(listener_i_utt)]
}

var meaning_table = {
  agent_falls: {the_agent: 1, the_patient: 0, it: 1, zero: 1},
  patient_falls: {the_agent: 0, the_patient: 1, it: 1, zero: 0}
}

// meaning function to interpret the utterances
var meaning = function(utterance, state){
  meaning_table[state][utterance]
}

//var jump_over_beta = DiscreteBeta(0.5451610, 0.6961924)
//var wave_bate = DiscreteBeta(1.1358936, 0.6326076)
//var attack_beta = DiscreteBeta(1.0033267, 0.4721537)
//var throw_rock_beta = DiscreteBeta(2.970715, 0.198752)

var actionPrior = function(action, action_prior)
{
  if (action_prior != -1)
  {
    return action_prior
  }
  else
  {
    return action_priors[action]
    /*return (action == 'jump_over') ? sample(jump_over_beta) :
      (action == 'wave') ? sample(wave_bate) :
      (action == 'attack') ? sample(attack_beta) :
      (action == 'throw_rock') ? sample(throw_rock_beta) :
      0.5*/
  }
}

var statePrior = function(params)
{
  //print(params.action)
  //print(params.action_prior)
  var p1 = actionPrior(params.action, params.action_prior)
  var p2 = 1 - params.salience_prior
  /*var p3 =
      params.event_type == 'familiar' ?
        state == "patient_falls" ? params.train_prior : 1 - params.train_prior :
      params.event_type == 'surprising' ?
        state == "patient_falls" ? 1 - params.train_prior : params.train_prior :
      0.5*/
  var p3 =
    params.event_type == "postsurprising" ?
      params.patient_color == 'blue' ? params.revision_prior :
      params.patient_color == 'red' ? 1 - params.revision_prior :
      0.5 :
    params.patient_color == 'blue' ? params.train_prior :
    params.patient_color == 'red' ? 1 - params.train_prior :
    0.5
  //var p3 = params.event_type == 'surprising' ? params.train_prior : 0.5
  
  return p1 * p2 * p3 / (p1 * p2 * p3 + (1 - p1) * (1 - p2) * (1 - p3)) // patient falling probability
}

var stateByPriors = function(params)
{
  var p = statePrior(params)
  
  var state_id = +flip(p)
  return states[state_id]
}


// DIRECT AND INVERSE RSA

// literal speaker
var speaker0 = function(state, params)
{
  Infer({model: function()
  {
    var utterance = utteranceByPrior(state, params)
    condition(meaning(utterance, state))
    return utterance
  }})
}

var literalSpeaker = speaker0

// literal listener
var listener0_sample = function(utterance, params)
{
  Infer
  (
    {
      model: function()
      {
        var state = stateByPriors(params)
        var i_utt = sample(intendedUtterancePosterior(utterance, state, params))
        condition(meaning(i_utt, state))
        return state
      }
    }
  )
}

var listener0_sum = function(utterance, params)
{
  Infer
  (
    {
      model: function()
      {
        var state = stateByPriors(params)

        var utility = sum
        (
          map
          (
            function(i_utt)
            {
              var utterance_prior = utterancePrior(i_utt, state, params)
              var confusion_prob = confusionProb(i_utt, utterance, params)
              var likelihood = meaning(i_utt, state)
              return utterance_prior * confusion_prob * likelihood
            },
            utterances
          )
        )

        factor(Math.log(utility))

        return state
      }
    }
  )
}

var listener0 = listener0_sum

var literalListener = listener0

// higher order speaker
var speakerN = function(n, state, params)
{
  if (n == 0)
  {
    return speaker0(state, params)
  }
  else
  {
    var salience_prior = (state == 'agent_falls' ? params.salience_prior : params.agent_bias)

    var patient_color =
      (params.event_type == "familiar")   ? (state == 'patient_falls') ? ('blue') : ('red') :
      (params.event_type == "surprising") ? (state == 'patient_falls') ? ('red') : ('blue'):
      (params.event_type == "postsurprising") ? (state == 'patient_falls') ? ('blue') : ('red'):
      ('yellow')

    var listener_params = Object.assign({}, params, {salience_prior: salience_prior, patient_color: patient_color})

    Infer({model: function()
    {
      var utterance = utteranceByPrior(state, params)

      var utility = sum
      (
        map
        (
          function(p_utt)
          {
            var confusion_prob = confusionProb(utterance, p_utt, params)
            var likelihood = listenerN(n - 1, p_utt, listener_params).score(state)
            return confusion_prob == 0 ? 0 : confusion_prob * likelihood
          },
          utterances
        )
      )
      
      factor(params.alpha == 0 ? 0 : params.alpha * utility)

      return utterance
    }
    })
  }
}

// higher order listener
var listenerN_sample = function(n, utterance, params)
{
  if (n == 0)
  {
    return listener0(utterance, params)
  }
  else
  {
    Infer
    (
      {
        model: function()
        {
          var state = stateByPriors(params)
          var i_utt = sample(intendedUtterancePosterior(utterance, state, params))
          observe(speakerN(n - 1, state, params), i_utt)
          return state
        }
      }
    )
  }
}

var listenerN_sum = function(n, utterance, params)
{
  if (n == 0)
  {
    return listener0(utterance, params)
  }
  else
  {
    Infer
    (
      {
        model: function()
        {
          var state = stateByPriors(params)

          var utility = sum
          (
            map
            (
              function(i_utt)
              {
                var utterance_prior = utterancePrior(i_utt, state, params)
                var confusion_prob = confusionProb(i_utt, utterance, params)
                var likelihood = Math.exp(speakerN(n - 1, state, params).score(i_utt))
                return utterance_prior * confusion_prob * likelihood
              },
              utterances
            )
          )

          factor(Math.log(utility))

          return state
        }
      }
    )
  }
}

var listenerN = listenerN_sum

// direct pragmatic speaker
var speaker1 = function(state, params)
{
  return speakerN(1, state, params)
}

var pragmaticSpeaker = speaker1

// direct pragmatic listener
var listener2 = function(utterance, params)
{
  return listenerN(2, utterance, params)
}

var pragmaticListener = listener2

// direct hyperpragmatic speaker
var speaker3 = function(state, params)
{
  return speakerN(3, state, params)
}

// inverse pragmatic listener
var listener1 = function(utterance, params)
{
  return listenerN(1, utterance, params)
}

var inversePragmaticListener = listener1

// inverse pragmatic speaker
var speaker2 = function(state, params)
{
  return speakerN(2, state, params)
}

var inversePragmaticSpeaker = speaker2


////////////////
// Data Analysis
