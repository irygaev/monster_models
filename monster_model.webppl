var modelMainExps = function(fitting_params, fixed_params)
{
  var alpha = uniform({a:1, b:10});
  var alpha_familiar = alpha//uniform({a:1, b:10});
  var alpha_surprising = alpha//uniform({a:1, b:10});
  var alpha_neutral = alpha//uniform({a:1, b:10});

  var np_cost = (fitting_params.cost == "np" || fitting_params.cost == "both") ? uniform({a:0, b:1}) : (0)
  var pro_cost = (fitting_params.cost == "pro" || fitting_params.cost == "both") ? uniform({a:0, b:1}) : (0)

  var certain_zero = uniform({a:0, b:1});
  var certain_it = uniform({a:0, b:1})
  var certain_surp = certain_zero//uniform({a:0, b:1})
  var certain_surp_it = certain_it//uniform({a:0, b:1})

  var certain_clean = uniform({a:0, b:1})
  var certain_clean_it = uniform({a:0, b:1})
  var certain_low = uniform({a:0, b:1})
  var certain_low_it = uniform({a:0, b:1})
  var certain_high = uniform({a:0, b:1})
  var certain_high_it = uniform({a:0, b:1})

  var salience_prior = 0.5//uniform({a:0, b:1})
  var agent_bias = uniform({a:0.6, b:1})
  var subject_bias = 0.5//uniform({a:0.6, b:1})
  
  var jump_over_prior = uniform({a:0, b:1})
  var wave_prior = uniform({a:0, b:1})
  var attack_prior = uniform({a:0, b:1})
  var throw_rock_prior = uniform({a:0, b:1})
  var overall_prior = uniform({a:0, b:1})
  
  var train_prior = uniform({a:0, b:1})
  var revision_prior = uniform({a:0, b:1})
  
  var random_params = {
      alpha: alpha,
      alpha_familiar: alpha_familiar,
      alpha_surprising: alpha_surprising,
      alpha_neutral: alpha_neutral,
      certain_zero: certain_zero,
      certain_it: certain_it,
      certain_surp: certain_surp,
      certain_surp_it: certain_surp_it,
      certain_clean: certain_clean,
      certain_clean_it: certain_clean_it,
      certain_low: certain_low,
      certain_low_it: certain_low_it,
      certain_high: certain_high,
      certain_high_it: certain_high_it,
      salience_prior: salience_prior,
      agent_bias: agent_bias,
      subject_bias: subject_bias,
      np_cost: np_cost,
      pro_cost: pro_cost,
      jump_over_prior: jump_over_prior,
      wave_prior: wave_prior,
      attack_prior: attack_prior,
      throw_rock_prior: throw_rock_prior,
      overall_prior: overall_prior,
      train_prior: train_prior,
      revision_prior: revision_prior
    }

  var params = Object.assign({}, random_params, fixed_params) // override random parameters by given fixed ones

  var local_action_priors = {jump_over: params.jump_over_prior, wave: params.wave_prior, attack: params.attack_prior, throw_rock: params.throw_rock_prior, overall: params.overall_prior}
  //var local_action_priors = action_priors

  var speaker_training = []/*map
  (
    function(action)
    {
      return {
        data: prod_data_training[action],
        params: {
          event_type: "neutral",
          action: action,
          alpha: params.alpha_prod,
          certain_zero: params.certain_zero,
          certain_it: params.certain_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost
        },
        speaker: fitting_params.speaker,
        states: states,
        utterances: utterances
      }
    },
    fitting_params.actions
  )*/

  var speaker_familiar = map
  (
    function(action)
    {
      return {
        data: prod_data_training_familiar[action],
        params: {
          event_type: "familiar",
          action: action,
          alpha: params.alpha_familiar,
          certain_zero: params.certain_zero,
          certain_it: params.certain_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost
        },
        speaker: fitting_params.speaker,
        states: states,
        //states: ["agent_falls"],
        utterances: utterances
      }
    },
    fitting_params.actions
  )

  var speaker_surprising = map
  (
    function(action)
    {
      return {
        data: prod_data_training_surprising[action],
        params: {
          event_type: "surprising",
          action: action,
          alpha: params.alpha_surprising,
          certain_zero: params.certain_surp,
          certain_it: params.certain_surp_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost,
        },
        speaker: fitting_params.speaker,
        states: states,
        //states: ["agent_falls"],
        utterances: utterances
      }
    },
    fitting_params.actions
  )

  var speaker_postsurprising = map
  (
    function(action)
    {
      return {
        data: prod_data_training_postsurprising[action],
        params: {
          event_type: "postsurprising",
          action: action,
          alpha: params.alpha_surprising,
          certain_zero: params.certain_surp,
          certain_it: params.certain_surp_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost,
        },
        speaker: fitting_params.speaker,
        states: states,
        //states: ["agent_falls"],
        utterances: utterances
      }
    },
    fitting_params.actions
  )

  var speaker_no_training = map
  (
    function(action)
    {
      return {
        data: prod_data_no_training_rest[action],
        params: {
          event_type: "neutral",
          action: action,
          alpha: params.alpha_neutral,
          certain_zero: params.certain_surp,
          certain_it: params.certain_surp_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost,
        },
        speaker: fitting_params.speaker,
        states: states,
        //states: ["agent_falls"],
        utterances: utterances
      }
    },
    fitting_params.actions
  )

  var speaker_experiments = fitting_params.speaker === null ? [] : speaker_training.concat(speaker_familiar.concat(speaker_surprising.concat(speaker_postsurprising.concat(speaker_no_training))))

  var listener_clean = map
  (
    function(action)
    {
      return {
        data: perc_data_clean[action],
        params: {
          event_type: "neutral",
          action: action,
          alpha: params.alpha,
          certain_zero: params.certain_clean,
          certain_it: params.certain_clean_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost
        },
        listener: fitting_params.listener,
        states: states,
        utterances: ["it", "zero"]
      }
    },
    fitting_params.actions
  )

  var listener_low_noise = map
  (
    function(action)
    {
      return {
        data: perc_data_low_noise[action],
        params: {
          event_type: "neutral",
          action: action,
          alpha: params.alpha,
          certain_zero: params.certain_low,
          certain_it: params.certain_low_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost
        },
        listener: fitting_params.listener,
        states: states,
        utterances: ["it", "zero"]
      }
    },
    fitting_params.actions
  )

  var listener_high_noise = map
  (
    function(action)
    {
      return {
        data: perc_data_high_noise[action],
        params: {
          event_type: "neutral",
          action: action,
          alpha: params.alpha,
          certain_zero: params.certain_high,
          certain_it: params.certain_high_it,
          salience_prior: params.salience_prior,
          agent_bias: agent_bias,
          subject_bias: subject_bias,
          action_prior: local_action_priors[action],
          train_prior: params.train_prior,
          revision_prior: revision_prior,
          np_cost: params.np_cost,
          pro_cost: params.pro_cost
        },
        listener: fitting_params.listener,
        states: states,
        utterances: ["it", "zero"]
      }
    },
    fitting_params.actions
  )

  var listener_experiments = fitting_params.listener === null ? [] : listener_clean.concat(listener_low_noise.concat(listener_high_noise))

  return {
    params: params,
    speaker_experiments: speaker_experiments,
    listener_experiments: listener_experiments
  }
}

var speakerTrialParams = function(experiment, state)
{
  /*var patient_color =
      (experiment.event_type == "familiar")   ? (state == 'patient_falls') ? ('blue') : ('red') :
      (experiment.event_type == "surprising") ? (state == 'patient_falls') ? ('red') : ('blue'):
      (experiment.event_type == "postsurprising") ? (state == 'patient_falls') ? ('blue') : ('red'):
      ('yellow')

  return {patient_color: patient_color}*/
  return {}
}

var listenerTrialParams = function(experiment, utterance)
{
  return {patient_color: "yellow"}
}

var dataAnalysis = function(model_generator, fitting_params, fixed_params)
{
  var model = model_generator(fitting_params, fixed_params)

  var predictions = {
    speaker:
      map(function(experiment){
        map(function(state){ 
              
          var speaker = experiment.speaker

          var speaker_predictions = speaker(state, Object.assign({}, experiment.params, speakerTrialParams(experiment, state)))
          var speaker_data = experiment.data[state]

          var utt_probs = map(function(utterance){ return Math.exp(speaker_predictions.score(utterance)) }, _.keys(speaker_data))
          var utt_count = map(function(utterance){ return speaker_data[utterance] }, _.keys(speaker_data))

          observe(Multinomial({n: sum(utt_count), ps: utt_probs}), utt_count)
          return multinomial({n: sum(utt_count), ps: utt_probs})
        },
        experiment.states)
      },
      model.speaker_experiments),
    
    listener:
      map(function(experiment){
        map(function(utterance){ 

          var listener = experiment.listener

          var listener_predictions = listener(utterance, Object.assign({}, experiment.params, listenerTrialParams(experiment, utterance)))
          var listener_data = experiment.data[utterance]

          var int_probs = map(function(state){ return Math.exp(listener_predictions.score(state)) }, _.keys(listener_data))
          var int_count = map(function(state){ return listener_data[state] }, _.keys(listener_data))

          observe(Multinomial({n: sum(int_count), ps: int_probs}), int_count)
          return multinomial({n: sum(int_count), ps: int_probs})
        },
        experiment.utterances)
      },
      model.listener_experiments)
  }
  
  return Object.assign({}, model.params, {samples: predictions}) // union of two dictionaries
}

var estimateAndSample = function(model_generator, fitting_params, fixed_params, n_samples, to_sample, filename)
{
  var burn_samples = 5000

  var parameter_estimation = Infer({
    method: "MCMC",
    samples: n_samples,
    burn: burn_samples,
    model: function() {dataAnalysis(model_generator, fitting_params, fixed_params)}})

  //viz(parameter_estimation)
  //viz.marginals(parameter_estimation)

  print("var params = {")
  map(
    function(param)
    {
      if (param != 'samples')
        print("  " + param + ": " + expectation(marginalize(parameter_estimation, param)) + ",")
    },
    _.keys(parameter_estimation.samples[0].value)
  )
  print("}")

  if (to_sample)
  {
    var samples = map(function(x) { x.value.samples }, parameter_estimation.samples)
    json.write(filename, samples.slice(burn_samples))
    print("sample saved")
  }
}

var modelScoreSample = function(model_generator, fitting_params, fixed_params)
{
  var model = model_generator(fitting_params, fixed_params)

  var speaker_score = sum(
    map(function(experiment){
      return sum(
        map(function(state){

          var speaker = experiment.speaker

          var speaker_predictions = speaker(state, Object.assign({}, experiment.params, speakerTrialParams(experiment, state)))
          var speaker_data = experiment.data[state]

          var utt_probs = map(function(utterance){ return Math.exp(speaker_predictions.score(utterance)) }, _.keys(speaker_data))
          var utt_count = map(function(utterance){ return speaker_data[utterance] }, _.keys(speaker_data))

          return Multinomial({n: sum(utt_count), ps: utt_probs}).score(utt_count)
        },
        experiment.states))
    },
    model.speaker_experiments))

  var listener_score = sum(
    map(function(experiment){
      return sum(
        map(function(u){

          var listener = experiment.listener

          var listener_predictions = listener(utterance, Object.assign({}, experiment.params, listenerTrialParams(experiment, utterance)))
          var listener_data = experiment.data[utterance]

          var int_probs = map(function(state){ return Math.exp(listener_predictions.score(state)) }, _.keys(listener_data))
          var int_count = map(function(state){ return listener_data[state] }, _.keys(listener_data))

          return Multinomial({n: sum(int_count), ps: int_probs}).score(int_count)

        },
        experiment.utterances))
    },
    model.listener_experiments))

  return Math.exp(speaker_score + listener_score)
}

var modelScore = function(model_generator, fitting_params, fixed_params, n_samples)
{
  var score = expectation
  (
    Infer
    (
      {
        method: "forward",
        samples: n_samples,
        model: function() {modelScoreSample(model_generator, fitting_params, fixed_params)}
      }
    )
  )

  return score
}

